      <aliases enabled='yes' />
      <column caption='Profit Ratio' datatype='real' name='[Calculation_0042374595371010]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])*100' />
      </column>
      <column caption='Discount Impact Category' datatype='string' name='[Calculation_0042374596411395]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Discount] = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF [Discount] &gt; 0 AND [Discount] &lt;= 0.2 THEN &quot;Low Discount&quot;&#13;&#10;ELSE &quot;High Discount&quot;&#13;&#10;END' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_1528914642116608]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
